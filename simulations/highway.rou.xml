<routes>
    <vType id="car"
           accel="3.0"
           decel="6.0"
           length="5"
           maxSpeed="30"/>

    <route id="highway" edges="A0B0"/>

    <!-- Platoon of 10 vehicles at 10m spacing, all departing at t=1s -->
    <!-- departSpeed=27.78 m/s = 100 km/h as in paper -->
    <flow id="platoon"
          type="car"
          route="highway"
          begin="1"
          end="2"
          number="10"
          departSpeed="27.78"
          departLane="0"
          departPos="incremental"/>
</routes>
